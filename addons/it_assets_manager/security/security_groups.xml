<odoo>
    <record id="group_it_asset_manager_technician" model="res.groups">
        <field name="name">Técnico IT</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="group_it_asset_employee" model="res.groups">
        <field name="name">Empleado</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="rule_it_asset_technician_all" model="ir.rule">
        <field name="name">IT Assets - Técnico ve todo</field>
        <field name="model_id" ref="model_it_asset"/>
        <field name="groups" eval="[(4, ref('group_it_asset_manager_technician'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_it_asset_employee_own" model="ir.rule">
        <field name="name">IT Assets - Empleado ve sus activos</field>
        <field name="model_id" ref="model_it_asset"/>
        <field name="groups" eval="[(4, ref('group_it_asset_employee'))]"/>
        <field name="domain_force">[('current_employee_id.user_id', '=', user.id)]</field>
    </record>

    <record id="rule_it_asset_assignment_technician_all" model="ir.rule">
        <field name="name">IT Asset Assignments - Técnico ve todo</field>
        <field name="model_id" ref="model_it_asset_assignment"/>
        <field name="groups" eval="[(4, ref('group_it_asset_manager_technician'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_it_asset_assignment_employee_own" model="ir.rule">
        <field name="name">IT Asset Assignments - Empleado ve lo suyo</field>
        <field name="model_id" ref="model_it_asset_assignment"/>
        <field name="groups" eval="[(4, ref('group_it_asset_employee'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>
</odoo>