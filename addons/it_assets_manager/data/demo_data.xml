<odoo noupdate="1">
    <record id="demo_partner_technician" model="res.partner">
        <field name="name">Tecnico IT Demo</field>
        <field name="email">tecnico.demo@example.com</field>
    </record>

    <record id="demo_partner_employee_1" model="res.partner">
        <field name="name">Empleado Demo 1</field>
        <field name="email">empleado1.demo@example.com</field>
    </record>

    <record id="demo_partner_employee_2" model="res.partner">
        <field name="name">Empleado Demo 2</field>
        <field name="email">empleado2.demo@example.com</field>
    </record>

    <record id="demo_partner_employee_3" model="res.partner">
        <field name="name">Empleado Demo 3</field>
        <field name="email">empleado3.demo@example.com</field>
    </record>

    <record id="demo_user_technician" model="res.users">
        <field name="name">Tecnico IT Demo</field>
        <field name="login">tecnico.demo@example.com</field>
        <field name="partner_id" ref="demo_partner_technician"/>
        <field name="groups_id" eval="[(4, ref('base.group_user')), (4, ref('it_assets_manager.group_it_asset_manager_technician'))]"/>
    </record>

    <record id="demo_user_employee_1" model="res.users">
        <field name="name">Empleado Demo 1</field>
        <field name="login">empleado1.demo@example.com</field>
        <field name="partner_id" ref="demo_partner_employee_1"/>
        <field name="groups_id" eval="[(4, ref('base.group_user')), (4, ref('it_assets_manager.group_it_asset_employee'))]"/>
    </record>

    <record id="demo_user_employee_2" model="res.users">
        <field name="name">Empleado Demo 2</field>
        <field name="login">empleado2.demo@example.com</field>
        <field name="partner_id" ref="demo_partner_employee_2"/>
        <field name="groups_id" eval="[(4, ref('base.group_user')), (4, ref('it_assets_manager.group_it_asset_employee'))]"/>
    </record>

    <record id="demo_user_employee_3" model="res.users">
        <field name="name">Empleado Demo 3</field>
        <field name="login">empleado3.demo@example.com</field>
        <field name="partner_id" ref="demo_partner_employee_3"/>
        <field name="groups_id" eval="[(4, ref('base.group_user')), (4, ref('it_assets_manager.group_it_asset_employee'))]"/>
    </record>

    <record id="demo_employee_technician" model="hr.employee">
        <field name="name">Tecnico IT Demo</field>
        <field name="user_id" ref="demo_user_technician"/>
    </record>

    <record id="demo_employee_1" model="hr.employee">
        <field name="name">Empleado Demo 1</field>
        <field name="user_id" ref="demo_user_employee_1"/>
    </record>

    <record id="demo_employee_2" model="hr.employee">
        <field name="name">Empleado Demo 2</field>
        <field name="user_id" ref="demo_user_employee_2"/>
    </record>

    <record id="demo_employee_3" model="hr.employee">
        <field name="name">Empleado Demo 3</field>
        <field name="user_id" ref="demo_user_employee_3"/>
    </record>

    <record id="demo_category_laptops" model="it.asset.category">
        <field name="name">Laptops</field>
        <field name="code">LTP</field>
    </record>

    <record id="demo_category_monitors" model="it.asset.category">
        <field name="name">Monitores</field>
        <field name="code">MON</field>
    </record>

    <record id="demo_category_licenses" model="it.asset.category">
        <field name="name">Licencias</field>
        <field name="code">LIC</field>
    </record>

    <record id="demo_category_peripherals" model="it.asset.category">
        <field name="name">Periféricos</field>
        <field name="code">PER</field>
    </record>

    <record id="demo_asset_1" model="it.asset">
        <field name="name">Laptop Dell 1</field>
        <field name="asset_type">laptop</field>
        <field name="serial_number">DELL-001</field>
        <field name="category_id" ref="demo_category_laptops"/>
        <field name="purchase_date">2024-02-10</field>
        <field name="warranty_end_date">2026-08-20</field>
        <field name="state">asignado</field>
    </record>

    <record id="demo_asset_2" model="it.asset">
        <field name="name">Laptop HP 2</field>
        <field name="asset_type">laptop</field>
        <field name="serial_number">HP-002</field>
        <field name="category_id" ref="demo_category_laptops"/>
        <field name="purchase_date">2023-11-05</field>
        <field name="warranty_end_date">2026-07-20</field>
        <field name="state">disponible</field>
    </record>

    <record id="demo_asset_3" model="it.asset">
        <field name="name">Monitor Samsung 1</field>
        <field name="asset_type">monitor</field>
        <field name="serial_number">SAM-101</field>
        <field name="category_id" ref="demo_category_monitors"/>
        <field name="purchase_date">2022-09-15</field>
        <field name="warranty_end_date">2025-12-01</field>
        <field name="state">mantenimiento</field>
    </record>

    <record id="demo_asset_4" model="it.asset">
        <field name="name">Licencia Office 1</field>
        <field name="asset_type">licencia</field>
        <field name="serial_number">LIC-OFF-01</field>
        <field name="category_id" ref="demo_category_licenses"/>
        <field name="purchase_date">2025-01-01</field>
        <field name="warranty_end_date">2026-09-15</field>
        <field name="state">disponible</field>
    </record>

    <record id="demo_asset_5" model="it.asset">
        <field name="name">Mouse Logitech 1</field>
        <field name="asset_type">periferico</field>
        <field name="serial_number">LOG-501</field>
        <field name="category_id" ref="demo_category_peripherals"/>
        <field name="purchase_date">2023-03-12</field>
        <field name="warranty_end_date">2024-03-12</field>
        <field name="state">baja</field>
    </record>

    <record id="demo_assignment_1" model="it.asset.assignment">
        <field name="asset_id" ref="demo_asset_1"/>
        <field name="employee_id" ref="demo_employee_1"/>
        <field name="assigned_date">2026-06-01</field>
        <field name="notes">Asignación inicial de demo.</field>
    </record>

    <record id="demo_assignment_2" model="it.asset.assignment">
        <field name="asset_id" ref="demo_asset_3"/>
        <field name="employee_id" ref="demo_employee_2"/>
        <field name="assigned_date">2026-05-12</field>
        <field name="returned_date">2026-06-10</field>
        <field name="notes">Cierre por mantenimiento.</field>
    </record>

    <record id="demo_assignment_3" model="it.asset.assignment">
        <field name="asset_id" ref="demo_asset_3"/>
        <field name="employee_id" ref="demo_employee_3"/>
        <field name="assigned_date">2026-06-15</field>
        <field name="notes">Reasignado después de mantenimiento.</field>
    </record>
</odoo>